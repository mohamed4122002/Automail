# ============================================================
# Marketing Automation Platform — Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your real values.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
ENV=development
APP_NAME=Marketing Automation Platform

# ── Database ─────────────────────────────────────────────────
# Used by docker-compose for POSTGRES_PASSWORD
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://automation_user:your_secure_password_here@db:5432/marketing_automation

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_secure_random_hex_string

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=generate_a_fernet_key

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email ────────────────────────────────────────────────────
EMAIL_FROM_DEFAULT=no-reply@yourdomain.com
FRONTEND_URL=http://localhost:5173
VITE_PROXY_TARGET=http://backend:8000

# ── Connection Pool (optional overrides) ─────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_STATEMENT_TIMEOUT_MS=30000
DB_LOCK_TIMEOUT_MS=5000
